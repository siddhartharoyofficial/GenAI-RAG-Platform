# =============================================================================
# Python runtime artifacts
# Compilation caches and test caches stay local. They should never be committed.
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# =============================================================================
# Terraform local state
# Auth, state, and tfvars files contain cloud credentials and resource IDs.
# These must NEVER be pushed to a public repo.
# =============================================================================
.terraform/
**/.terraform/*
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
!terraform.tfvars.example
tfplan
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =============================================================================
# Environment secrets
# Any file holding credentials, API keys, or environment-specific config.
# Blocking these eliminates the data-exfiltration risk of a careless commit.
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.crt
credentials.json
service-account*.json
gcp-key*.json

# =============================================================================
# Build / dist / venv
# =============================================================================
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Virtualenv
venv/
.venv/
env/
ENV/

# =============================================================================
# IDE / OS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Docker / Kubernetes
# =============================================================================
.docker/
kubeconfig
*.kubeconfig

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
